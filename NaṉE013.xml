<text xml:lang="ta" type="edition">
  <body>
    <div rend="parallel">
      <lg xml:id="NaṉE013">
<l>nutalip pukuta lōttumuṟai vaippē</l>
<l>tokuttuc cuṭṭal vakuttuk kāṭṭal</l>
<l>muṭittuk kāṭṭaṉ muṭiviṭaṅ kūṟal</l>
<l>tāṉeṭuttu moḻital piṟaṉkōṭ kūṟal</l>
<l>coṟporuḷ viritta ṟoṭarccoṟ puṇarttal</l>
<l>iraṭṭuṟa moḻita lētuviṉ muṭittal</l>
<l>oppiṉ muṭittaṉ māṭṭeṟin toḻukal</l>
<l>iṟantatu vilakka letiratu pōṟṟal</l>
<l>muṉmoḻintu kōṭal piṉṉatu niṟuttal</l>
<l>vikaṟpattiṉ muṭittaṉ muṭintavai muṭittal</l>
<l>uraittu meṉṟa luraittā meṉṟal</l>
<l>orutalai tuṇita leṭuttuk kāṭṭal</l>
<l>eṭutta moḻiyi ṉeyta vaittal</l>
<l>iṉṉa talla tituveṉa moḻital</l>
<l>eñciya colli ṉeytak kūṟal</l>
<l>piṟanūṉ muṭintatu tāṉuṭam paṭutal</l>
<l>taṉkuṟi vaḻakka mikaveṭut turaittal</l>
<l>colliṉ muṭivi ṉapporuṇ muṭittal</l>
<l>oṉṟiṉa muṭitta ṟaṉṉiṉa muṭittal</l>
<l>uyttuṇara vaippeṉa vuttiyeṇ ṇāṉkē</l>
      </lg>
      <lg xml:lang="en">
